
class Main {
    public static void MoveZero(int num[]){
        int i = 0; 
        for(int j=0;j<num.length;j++){
            if(num[j] != 0){
                int temp = num[i];
                num[i] = num[j];
                num[j] = temp;
                i++;
            }
        }
       for(int n :num){
           System.out.print(n);
       }
    }
    public static void main(String[] args) {
        int num[] = {1,0,2,0,3};
        MoveZero(num);
    }
}
